# ── Strava ────────────────────────────────────────────────────────────────────
# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Run setup/get_strava_token.py once to obtain this
STRAVA_REFRESH_TOKEN=

# The numeric ID in your club URL: strava.com/clubs/<CLUB_ID>
STRAVA_CLUB_ID=

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Paste the FULL JSON content of your service account key file here (one line)
# Generate at: console.cloud.google.com → IAM & Admin → Service Accounts
GOOGLE_SERVICE_ACCOUNT_JSON=

# The ID from your Google Sheet URL:
# docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs. Group IDs are negative, personal chats are positive.
# To find IDs: send a message to the bot/group, then open:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
TELEGRAM_CHAT_IDS=

# ── Goal / Formatting (optional — these have defaults) ────────────────────────
ANNUAL_GOAL_KM=12000
TOTAL_WEEKS=52

# Public read-only Google Sheet URL shown at the bottom of each post.
# Leave empty to omit.
SHEET_PUBLIC_URL=

# Comma-separated Strava sport types to count. Leave empty for ALL types.
# Example: Run,Walk,Hike,VirtualRun
SPORT_TYPES=
